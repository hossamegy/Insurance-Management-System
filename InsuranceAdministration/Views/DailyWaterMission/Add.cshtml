@{
    ViewData["Title"] = "مهام المسطح المائي اليومية";
    ViewData["SubTitle"] = "إدارة وتوزيع المهام اليومية";
    Layout = "_Layout";
}

<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/DailyWaterMission/DailyWaterMissionView.css" asp-append-version="true" />
    <style>
        .personnel-row {
            display: flex;
            gap: 10px;
            margin-bottom: 8px;
            align-items: center;
        }

            .personnel-row:last-child {
                margin-bottom: 0;
            }

        .personnel-container {
            display: flex;
            flex-direction: column;
        }

        .add-person-btn {
            padding: 4px 12px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            margin-top: 5px;
        }

            .add-person-btn:hover {
                background: #218838;
            }

        .remove-person-btn {
            padding: 4px 8px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
        }

            .remove-person-btn:hover {
                background: #c82333;
            }

        .personnel-inputs {
            display: flex;
            gap: 10px;
            flex: 1;
        }

        /* Remove all borders */
        .modern-table td,
        .modern-table th {
            border: none;
        }

        .modern-table tbody tr {
            border-bottom: none;
        }

        .modern-table thead th {
            border: none;
        }

        .police-section,
        .police-col,
        .police-cell {
            border-left: none !important;
            border-right: none !important;
        }

        .soldier-section,
        .soldier-col,
        .soldier-cell {
            border-left: none !important;
            border-right: none !important;
        }

        .sticky-col {
            border-right: none !important;
        }
    </style>
</head>

@await Html.PartialAsync("_PageHeader")

<body>
    <div class="container m-0">
        <div class="modern-card">
            <div class="card-body p-4">
                <div class="table-container">
                    <h2>1- خدمات المسطح المائى</h2>
                    <table class="modern-table">
                        <thead>
                            <tr class="table-header-primary">
                                <th class="sticky-col" rowspan="2">#</th>
                                <th colspan="4">بيانات الخدمة</th>
                                <th class="police-section" colspan="3">أفراد الشرطة</th>
                                <th class="police-section" rowspan="2">إضافة</th>
                                <th class="soldier-section" colspan="2">المجندين</th>
                                <th class="soldier-section" rowspan="2">إضافة</th>
                            </tr>
                            <tr class="table-header-secondary">
                                <th>كود الخدمة</th>
                                <th>اسم الخدمة</th>
                                <th>اللنش</th>
                                <th>رقم الأسلكي</th>
                                <th class="police-col">الاسم</th>
                                <th class="police-col">رقم الهاتف</th>
                                <th class="police-col">السلاح</th>
                                <th class="soldier-col">الاسم</th>
                                <th class="soldier-col">رقم الهاتف</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int counter = 0;
                            }
                            @foreach (var mission in ViewBag.Missions)
                            {
                                counter++;
                                <tr>
                                    <td class="sticky-col">
                                        <span class="badge-number">@counter</span>
                                    </td>
                                    <td><span class="code-badge">@mission.CodeNumber</span></td>
                                    <td class="fw-semibold">@mission.Name</td>
                                    <td>@mission.BoatNumber</td>
                                    <td>@mission.WirelessCallSign</td>

                                    <!-- Police Officers -->
                                    <td class="police-cell" colspan="3">
                                        <div class="personnel-container police-container" data-mission-id="@mission.Id">
                                            <div class="personnel-row">
                                                <div class="personnel-inputs">
                                                    <select class="modern-select police-select" style="flex: 2;">
                                                        <option value="">اختر فرد شرطة</option>
                                                        @foreach (var police in ViewBag.PoliceMen)
                                                        {
                                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                                @police.Text.Split('|')[0]
                                                            </option>
                                                        }
                                                    </select>
                                                    <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                                    <input class="modern-input police-weapon" placeholder="رقم السلاح" style="flex: 1;" />
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <button type="button" class="add-person-btn add-police-btn">
                                            <i class="fas fa-plus"></i> +
                                        </button>
                                    </td>

                                    <!-- Soldiers -->
                                    <td class="soldier-cell" colspan="2">
                                        <div class="personnel-container soldier-container" data-mission-id="@mission.Id">
                                            <div class="personnel-row">
                                                <div class="personnel-inputs">
                                                    <select class="modern-select soldier-select" style="flex: 1;">
                                                        <option value="">اختر المجند</option>
                                                        @foreach (var soldier in ViewBag.Soldiers)
                                                        {
                                                            <option value="@soldier.Value" data-phone="@soldier.Text.Split('|')[1]">
                                                                @soldier.Text.Split('|')[0]
                                                            </option>
                                                        }
                                                    </select>
                                                    <input class="modern-input soldier-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <button type="button" class="add-person-btn add-soldier-btn">
                                            <i class="fas fa-plus"></i> +
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h2>2- الخدمات المعاونة</h2>
                <div class="table-container">
                    <table class="modern-table">
                        <thead>
                            <tr class="table-header-primary">
                                <th>منوب السلاح</th>
                                <th>منوب المعسكر</th>
                                <th>بريد + اتصالات</th>
                                <th>شئون افراد</th>
                                <th>مرسى</th>
                                <th>عهدة</th>
                                <th>صيانة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="weapon-deputy">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="camp-deputy">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="mail-comms">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="personnel">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="marina">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="custody">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td class="police-cell">
                                    <select class="modern-select police-select support-service-select" data-service="maintenance">
                                        <option value="">اختر فرد شرطة</option>
                                        @foreach (var police in ViewBag.PoliceMen)
                                        {
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div>
                    <h2>3 - خارج الخدمة</h2>
                    <table class="modern-table">
                        <thead>
                            <tr class="table-header-primary">
                                <th class="sticky-col" rowspan="2">#</th>
                                <th>بيانات الخدمة</th>
                                <th class="police-section" colspan="4">أفراد الشرطة</th>
                                <th class="police-section" rowspan="2">إضافة</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td class="sticky-col">
                                    <span class="badge-number">1</span>
                                </td>
                                <td class="fw-semibold">مرضى</td>
                                <td class="sticky-col">
                                    <input class="modern-input" placeholder="ملحوظة" />
                                </td>
                                <!-- Police Officers -->
                                <td class="police-cell" colspan="3">
                                    <div class="personnel-container police-container">
                                        <div class="personnel-row">
                                            <div class="personnel-inputs">
                                                <select class="modern-select police-select" style="flex: 2;">
                                                    <option value="">اختر فرد شرطة</option>
                                                    @foreach (var police in ViewBag.PoliceMen)
                                                    {
                                                        <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                            @police.Text.Split('|')[0]
                                                        </option>
                                                    }
                                                </select>
                                                <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <button type="button" class="add-person-btn add-min-police-btn">
                                        <i class="fas fa-plus"></i> +
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td class="sticky-col">
                                    <span class="badge-number">2</span>
                                </td>
                                <td class="fw-semibold">راحة</td>
                                <td class="sticky-col">
                                    <input class="modern-input" placeholder="ملحوظة" />
                                </td>
                                <!-- Police Officers -->
                                <td class="police-cell" colspan="3">
                                    <div class="personnel-container police-container">
                                        <div class="personnel-row">
                                            <div class="personnel-inputs">
                                                <select class="modern-select police-select" style="flex: 2;">
                                                    <option value="">اختر فرد شرطة</option>
                                                    @foreach (var police in ViewBag.PoliceMen)
                                                    {
                                                        <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                            @police.Text.Split('|')[0]
                                                        </option>
                                                    }
                                                </select>
                                                <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <button type="button" class="add-person-btn add-min-police-btn">
                                        <i class="fas fa-plus"></i> +
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td class="sticky-col">
                                    <span class="badge-number">3</span>
                                </td>
                                <td class="fw-semibold">مأمورية خارجية</td>
                                <td class="sticky-col">
                                    <input class="modern-input police-phone" placeholder="ملحوظة" readonly style="flex: 1;" />
                                </td>
                                <!-- Police Officers -->
                                <td class="police-cell" colspan="3">
                                    <div class="personnel-container police-container">
                                        <div class="personnel-row">
                                            <div class="personnel-inputs">
                                                <select class="modern-select police-select" style="flex: 2;">
                                                    <option value="">اختر فرد شرطة</option>
                                                    @foreach (var police in ViewBag.PoliceMen)
                                                    {
                                                        <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                            @police.Text.Split('|')[0]
                                                        </option>
                                                    }
                                                </select>
                                                <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <button type="button" class="add-person-btn add-min-police-btn">
                                        <i class="fas fa-plus"></i> +
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="action-bar">
                    <button class="btn-modern btn-primary-modern">
                        <i class="fas fa-save"></i> حفظ المهام
                    </button>
                    <button class="btn-modern btn-secondary-modern">
                        <i class="fas fa-redo"></i> إعادة تعيين
                    </button>
                    <button class="btn-modern btn-outline-modern">
                        <i class="fas fa-times"></i> إلغاء
                    </button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            $(document).ready(function () {
                // Handle police select change
                $(document).on('change', '.police-select', function () {
                    let opt = $(this).find(':selected');
                    let phoneInput = $(this).closest('.personnel-inputs, .police-cell').find('.police-phone');
                    phoneInput.val(opt.data('phone') || '').toggleClass('filled', opt.data('phone'));
                });

                // Handle soldier select change
                $(document).on('change', '.soldier-select', function () {
                    let opt = $(this).find(':selected');
                    let phoneInput = $(this).closest('.personnel-inputs').find('.soldier-phone');
                    phoneInput.val(opt.data('phone') || '').toggleClass('filled', opt.data('phone'));
                });

                // Add police officer
                $(document).on('click', '.add-police-btn', function () {
                    let row = $(this).closest('tr');
                    let container = row.find('.police-container');
                    let newRow = `
                        <div class="personnel-row">
                            <div class="personnel-inputs">
                                <select class="modern-select police-select" style="flex: 2;">
                                    <option value="">اختر فرد شرطة</option>
                                    @foreach (var police in ViewBag.PoliceMen)
                                    {
                                            <text>
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                            </text>
                                    }
                                </select>
                                <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                                <input class="modern-input police-weapon" placeholder="رقم السلاح" style="flex: 1;" />
                            </div>
                            <button type="button" class="remove-person-btn">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    `;
                    container.append(newRow);
                });

                $(document).on('click', '.add-min-police-btn', function () {
                    let row = $(this).closest('tr');
                    let container = row.find('.police-container');
                    let newRow = `
                        <div class="personnel-row">
                            <div class="personnel-inputs">
                                <select class="modern-select police-select" style="flex: 2;">
                                    <option value="">اختر فرد شرطة</option>
                                    @foreach (var police in ViewBag.PoliceMen)
                                    {
                                            <text>
                                            <option value="@police.Value" data-phone="@police.Text.Split('|')[1]">
                                                @police.Text.Split('|')[0]
                                            </option>
                                            </text>
                                    }
                                </select>
                                <input class="modern-input police-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                            </div>
                            <button type="button" class="remove-person-btn">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    `;
                    container.append(newRow);
                });

                // Add soldier
                $(document).on('click', '.add-soldier-btn', function () {
                    let row = $(this).closest('tr');
                    let container = row.find('.soldier-container');
                    let newRow = `
                        <div class="personnel-row">
                            <div class="personnel-inputs">
                                <select class="modern-select soldier-select" style="flex: 1;">
                                    <option value="">اختر المجند</option>
                                    @foreach (var soldier in ViewBag.Soldiers)
                                    {
                                            <text>
                                            <option value="@soldier.Value" data-phone="@soldier.Text.Split('|')[1]">
                                                @soldier.Text.Split('|')[0]
                                            </option>
                                            </text>
                                    }
                                </select>
                                <input class="modern-input soldier-phone" placeholder="رقم الهاتف" readonly style="flex: 1;" />
                            </div>
                            <button type="button" class="remove-person-btn">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    `;
                    container.append(newRow);
                });

                // Remove person
                $(document).on('click', '.remove-person-btn', function () {
                    $(this).closest('.personnel-row').remove();
                });
            });
        </script>
    }
</body>