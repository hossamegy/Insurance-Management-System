@model IEnumerable<InsuranceAdministration.Core.Entities.MissionEntities.DailyMission>
@{
    ViewData["Title"] = "إدارة المهام اليومية";
}

<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: 'Traditional Arabic', 'Arial', sans-serif;
            background: #f5f5f5;
            direction: rtl;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #0090b0;
        }

        .page-title {
            font-size: 32px;
            font-weight: bold;
            color: #0090b0;
        }

        .btn {
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s ease;
        }

        .btn-primary {
            background: #0090b0;
            color: white;
        }

            .btn-primary:hover {
                background: #006080;
            }

        .btn-success {
            background: #28a745;
            color: white;
        }

            .btn-success:hover {
                background: #218838;
            }

        .btn-danger {
            background: #dc3545;
            color: white;
        }

            .btn-danger:hover {
                background: #c82333;
            }

        .btn-warning {
            background: #ffc107;
            color: #212529;
        }

            .btn-warning:hover {
                background: #e0a800;
            }

        .btn-info {
            background: #17a2b8;
            color: white;
        }

            .btn-info:hover {
                background: #138496;
            }

        .btn-sm {
            padding: 5px 10px;
            font-size: 14px;
        }

        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
            font-weight: bold;
        }

        .alert-success {
            background-color: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }

        .alert-warning {
            background-color: #fff3cd;
            border: 1px solid #ffeaa7;
            color: #856404;
        }

        .alert-danger {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

            .data-table thead {
                background: #0090b0;
                color: white;
            }

            .data-table th,
            .data-table td {
                padding: 12px;
                text-align: center;
                border: 1px solid #ddd;
            }

            .data-table th {
                font-weight: bold;
                font-size: 18px;
            }

            .data-table tbody tr:nth-child(even) {
                background: #f8f9fa;
            }

            .data-table tbody tr:hover {
                background: #e9ecef;
            }

        .badge {
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: bold;
            display: inline-block;
            margin: 2px;
        }

        .badge-river {
            background: #17a2b8;
            color: white;
        }

        .badge-department {
            background: #6f42c1;
            color: white;
        }

        .actions {
            display: flex;
            gap: 5px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .no-data {
            text-align: center;
            padding: 40px;
            font-size: 18px;
            color: #6c757d;
        }

        .search-box {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

            .search-box input {
                padding: 10px;
                border: 1px solid #ddd;
                border-radius: 4px;
                font-size: 16px;
                font-family: inherit;
                flex: 1;
            }

        .missions-list {
            display: flex;
            flex-direction: column;
            gap: 5px;
            max-height: 100px;
            overflow-y: auto;
        }

        .mission-count {
            background: #e9ecef;
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: bold;
            color: #495057;
        }

        .expandable-cell {
            cursor: pointer;
            position: relative;
        }

            .expandable-cell:hover {
                background: #dee2e6;
            }

        .expand-icon {
            margin-right: 5px;
            font-size: 12px;
        }

        .missions-details {
            display: none;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 4px;
            margin-top: 5px;
        }

            .missions-details.show {
                display: block;
            }

        .day-name {
            font-weight: bold;
            color: #0090b0;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Alert Messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning">
                @TempData["WarningMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">إدارة المهام اليومية</h1>
            <a asp-controller="Soldier" asp-action="DailyMission" class="btn btn-primary">
                <i class="fas fa-plus"></i> إنشاء مهام يومية جديدة
            </a>
        </div>

        <!-- Search Box -->
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="ابحث بالتاريخ..." onkeyup="filterTable()">
        </div>

        <!-- Daily Missions Table -->
        @if (Model != null && Model.Any())
        {
            <table class="data-table" id="dailyMissionsTable">
                <thead>
                    <tr>
                        <th>م</th>
                        <th>التاريخ</th>
                        <th>اليوم</th>
                        <th>عدد المهام</th>
                        <th>المهام</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int counter = 1;
                        string[] arabicDays = { "الأحد", "الاثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت" };
                    }
                    @foreach (var dailyMission in Model)
                    {
                        var dayName = arabicDays[(int)dailyMission.Date.DayOfWeek];
                        var uniqueMissions = dailyMission.SoldierMissions?
                        .Select(sm => sm.Mission)
                        .DistinctBy(m => m.Id)
                        .ToList() ?? new List<Mission>();

                        <tr>
                            <td>@counter</td>
                            <td>@dailyMission.Date.ToString("dd/MM/yyyy")</td>
                            <td><span class="day-name">@dayName</span></td>
                            <td>
                                <span class="mission-count">@uniqueMissions.Count مهمة</span>
                            </td>
                            <td class="expandable-cell" onclick="toggleMissions(@dailyMission.Id)">
                                <span class="expand-icon" id="icon-@dailyMission.Id">▼</span>
                                <span>عرض التفاصيل</span>
                                <div class="missions-details" id="details-@dailyMission.Id">
                                    @if (uniqueMissions.Any())
                                    {
                                        <div class="missions-list">
                                            @foreach (var mission in uniqueMissions)
                                            {
                                                var soldiersCount = dailyMission.SoldierMissions
                                                .Count(sm => sm.MissionId == mission.Id);

                                                <div>
                                                    @if (mission.MissionType == 0)
                                                    {
                                                        <span class="badge badge-river">مسطح مائي</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-department">ديوان</span>
                                                    }
                                                    <strong>@mission.Name</strong>
                                                    <span style="color: #6c757d;">(@soldiersCount جندي)</span>
                                                    @if (!string.IsNullOrEmpty(mission.BoatNumber))
                                                    {
                                                        <span> - لنش: @mission.BoatNumber</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p style="margin: 0; color: #6c757d;">لا توجد مهام</p>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="actions">
                                    <a asp-action="ShowDailyMission" asp-route-id="@dailyMission.Id" class="btn btn-info btn-sm">
                                        عرض
                                    </a>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete(@dailyMission.Id, '@dailyMission.Date.ToString("dd/MM/yyyy")')">
                                        حذف
                                    </button>
                                </div>
                            </td>
                        </tr>
                        counter++;
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="no-data">
                <p>لا توجد مهام يومية مسجلة</p>
                <a asp-controller="Soldier" asp-action="DailyMission" class="btn btn-primary">إنشاء مهام يومية جديدة</a>
            </div>
        }
    </div>

    <!-- Delete Confirmation Form (Hidden) -->
    <form id="deleteForm" asp-action="DeleteDailyMission" method="post" style="display: none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteId" />
    </form>

    <script>
        function filterTable() {
            const searchInput = document.getElementById('searchInput').value.toLowerCase();
            const table = document.getElementById('dailyMissionsTable');
            if (!table) return;

            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                const date = row.cells[1].textContent.toLowerCase();
                const day = row.cells[2].textContent.toLowerCase();

                const matchesSearch = date.includes(searchInput) || day.includes(searchInput);

                if (matchesSearch) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            }
        }

        function toggleMissions(id) {
            const details = document.getElementById('details-' + id);
            const icon = document.getElementById('icon-' + id);

            if (details.classList.contains('show')) {
                details.classList.remove('show');
                icon.textContent = '▼';
            } else {
                details.classList.add('show');
                icon.textContent = '▲';
            }
        }

        function confirmDelete(id, date) {
            if (confirm(`هل أنت متأكد من حذف المهام اليومية بتاريخ "${date}"؟\nسيتم حذف جميع المهام المرتبطة بهذا التاريخ.\nلا يمكن التراجع عن هذا الإجراء.`)) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
</body>
</html>