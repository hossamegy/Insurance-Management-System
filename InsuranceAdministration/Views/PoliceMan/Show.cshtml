@using InsuranceAdministration.Core.Entities.SoldierEntities
@model Soldier
@{
}
<head>
    <link rel="stylesheet" href="~/css/Shared/Show.css" asp-append-version="true" />
</head>
<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header text-white">
            <h3 class="mb-0">بيانات المجند</h3>
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-6 mb-2"><strong>الاسم:</strong> @Model.Name</div>
                <div class=""><strong>الرقم القومي:</strong> @Model.NationalId</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4"><strong>تاريخ الميلاد:</strong> @Model.BirthDate.ToString("dd/MM/yyyy")</div>
                <div class="col-md-4"><strong>تاريخ التجنيد:</strong> @Model.EnlistmentDate.ToString("dd/MM/yyyy")</div>
                <div class="col-md-4"><strong>تاريخ انتهاء الخدمة:</strong> @Model.ServiceEndDate?.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4"><strong>رقم الشرطة:</strong> @Model.PoliceNumber</div>
                <div class="col-md-4"><strong>الرقم الثلاثي:</strong> @Model.TripleNumber</div>
                <div class="col-md-4"><strong>رقم الهاتف:</strong> @Model.PhoneNumber</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4"><strong>المؤهل الدراسي:</strong> @Model.EducationLevel</div>
                <div class="col-md-4"><strong>التشغيل:</strong> @Model.Assignment</div>
                <div class="col-md-4"><strong>البلد:</strong> @Model.Street</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4"><strong>المركز:</strong> @Model.Region</div>
                <div class="col-md-4"><strong>المحافظة:</strong> @Model.City</div>
            </div>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Index" asp-controller="Soldier" class="btn btn-secondary">رجوع</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
        </div>
    </div>
</div>
