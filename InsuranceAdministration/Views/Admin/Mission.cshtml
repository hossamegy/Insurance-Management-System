@model Mission

<h1>إعدادات خدمات المسطح المائى</h1>

<table class="table table-bordered text-center align-middle">
    <thead>
        <tr>
            <th>م</th>
            <th>كود الخدمة</th>
            <th>اسم الخدمة</th>
            <th>رقم اللنش</th>
            <th>رقم الجهاز اللاسلكى</th>
            <th>حالة الخدمة</th>
            <th>تحديث</th>
        </tr>
    </thead>
    <tbody>
        @{
            var missions = ViewBag.Missions as List<Mission> ?? new List<Mission>();
            int counter = 1;
        }

        <!-- Existing missions -->
        @foreach (var mission in missions)
        {
            <tr>
                <td>@counter</td>

                <td>
                    <input name="CodeNumber" value="@mission.CodeNumber" class="form-control" form="update-@mission.Id" />
                </td>
                <td>
                    <input name="Name" value="@mission.Name" class="form-control" form="update-@mission.Id" />
                </td>
                <td>
                    <input name="BoatNumber" value="@mission.BoatNumber" class="form-control" form="update-@mission.Id" />
                </td>
                <td>
                    <input name="WirelessCallSign" value="@mission.WirelessCallSign" class="form-control" form="update-@mission.Id" />
                </td>
              
                
                <td class="d-flex raw">
                    @if (mission.IsActive == true)
                    {
                        <label name="WirelessCallSign" value="@mission.WirelessCallSign" class="form-control bg-primary text-light">تعمل</label>
                    }
                    else
                    {
                        <label name="WirelessCallSign" value="@mission.WirelessCallSign" class="form-control bg-danger text-light">متوقفة</label>

                    }
                    <select name="IsActive" class="form-control" form="update-@mission.Id">
                        <option value="">-- اختار حالة الخدمة --</option>
                        <option value="true">تعمل</option>
                        <option value="false">متوقفة</option>
                    </select>

                </td>
                <!-- Update button -->
                <td>
                    <form id="update-@mission.Id" asp-action="UpdateMission" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@mission.Id" />
                        <button type="submit" class="btn btn-success btn-sm">تحديث</button>
                    </form>
                </td>
            </tr>
            counter++;
        }

        <!-- Row for adding a new mission -->
        <tr>
            <td>@counter</td>
            <td><input name="CodeNumber" class="form-control" form="add-mission" /></td>
            <td><input name="Name" class="form-control" form="add-mission" /></td>
            <td><input name="BoatNumber" class="form-control" form="add-mission" /></td>
            <td><input name="WirelessCallSign" class="form-control" form="add-mission" /></td>

            <td colspan="2">
                <form id="add-mission" asp-action="AddNewMission" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-sm w-100">إضافة</button>
                </form>
            </td>
        </tr>
    </tbody>
</table>
