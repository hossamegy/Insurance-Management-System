@model InsuranceAdministration.Core.Entities.SoldierEntities.Soldier
@{
    Layout = null;
}

@functions {
    public static string ToArabicNumerals(string input)
    {
        if (string.IsNullOrEmpty(input)) return input;

        return input
            .Replace('0', '٠')
            .Replace('1', '١')
            .Replace('2', '٢')
            .Replace('3', '٣')
            .Replace('4', '٤')
            .Replace('5', '٥')
            .Replace('6', '٦')
            .Replace('7', '٧')
            .Replace('8', '٨')
            .Replace('9', '٩');
    }
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>أورنيك 114 شرطة</title>
    <style>
        @@media print {
            @@page {
                size: A4;
                margin: 2cm;
            }

            body {
                print-color-adjust: exact;
                -webkit-print-color-adjust: exact;
            }

            .no-print {
                display: none !important;
            }

            .document-container {
                border: 2px solid #000 !important;
            }
        }

        * {
            margin-right: 5px;
            margin-left: 5px;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Traditional Arabic', 'Simplified Arabic', 'Arial', sans-serif;
            background: #ffffff;
            padding: 10px;
            direction: rtl;
            line-height: 1.2;
        }

        .document-container {
            max-width: 21cm;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border: 2px solid #000;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .header-right {
            margin-top:10px;
            text-align: center;
        }

            .header-right div {
                font-size: 14px;
                font-weight: bold;
                color: #000;
            }

        .header-center {
            text-align: center;
            flex: 1;
        }

            .header-center div {
                font-size: 26px;
                font-weight: bold;
          
            }

        .header-left {
            text-align: left;
            flex: 1;
            display: flex;
            justify-content: flex-end;
        }

        .img-logo {
            width: 130px;
            height: 130px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: bold;
            text-align: center;
          
        }
        

        .document-title {
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            color: #000;
        }

        .soldier-info {
            display: flex;
            margin-right: 20px;
            gap: 15px;
        }

            .soldier-info div {
                flex: 1;
                font-size: 20px;
                font-weight: bold;
                padding: 5px;
                margin-right: 10px
            }

        .main-table {
            width: 100%;
            border-collapse: collapse;
            margin: 8px 0;
        }

            .main-table th,
            .main-table td {
                border: 1px solid #000;
                padding: 6px 8px;
                text-align: right;
                font-size: 20px;
            }

            .main-table th {
                color: #000;
                font-weight: bold;
                text-align: center;
                background: #fff;
            }

            .main-table td {
                background: #fff;
            }


        .section-title {
            font-size: 22px;
            font-weight: bold;
            color: #000;
            margin: 8px 0 6px 0;
            padding: 6px;
            text-align: center;
            text-decoration: underline;
            background: #fff;
        }

        .committee-members {
            display: flex;
            align-content: center;
            justify-content: center;
            align-items: center;
            min-height: 70px;
            gap: 50px;
        }

        .member-card {
            
            text-align: center;
            display: flex;
            justify-content: center;
            align-items:center;
        }

            .member-card div {
                margin-bottom: 3px;
                font-size: 18px;
            }

        .member-title {
            font-weight: bold;
            font-size: 10px;
       
        }

        .member-rank {
            font-weight: bold;
        }

        .member-section {
            line-height: 2.5;
        }
        .approval-section {
            text-align: center;
            font-size: 22px;
            font-weight: bold;
            margin: 8px 0;
            padding: 10px;
            text-decoration: underline;
        }

        .details-table {
            width: 100%;
            border-collapse: collapse;
        }

            .details-table td {
                border: 1px solid #000;
                padding: 10px;
                font-size: 18px;
                line-height: 1.4;
                font-weight: bold;
            }



        .signature-section {
            margin-top: 15px;
            text-align: start;
        }

        .signature-box {
            margin-right: 500px;
            text-align: start;
            font-size: 18px;
            font-weight: bold;
            height: 30px;
        }



        .print-button {
            margin: 15px 0 0 0;
            text-align: center;
        }

        .btn-print {
            padding: 10px 25px;
            background: #000;
            color: white;
            border: 2px solid #000;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            margin: 0 5px;
        }

            .btn-print:hover {
                background: #333;
            }

            .btn-print.secondary {
                background: #fff;
                color: #000;
            }

                .btn-print.secondary:hover {
                    background: #f0f0f0;
                }

        @@media print {
            .document-container {
                padding: 15px;
            }

            body {
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="document-container">
        <!-- Print Button -->
        <div class="print-button no-print">
            <button onclick="window.print()" class="btn-print">طباعة النموذج</button>
            <a asp-action="Ornik114" class="btn-print secondary">إغلاق</a>
        </div>

        <!-- Header -->
        <div class="header-section">
            <div class="header-right">
                <div>وزارة الداخلية</div>
                <div>قطاع الشرطة المتخصصة</div>
                <div>الإدارة العامة لشرطة البيئة والمسطحات</div>
                <div style="text-decoration:underline;">@ViewBag.DepartmentName</div>
            </div>

            <div class="header-left">
                <img src="~/LOGO.png" alt="Logo" class="img-logo"/>
            </div>
        </div>
        <div class="header-center">
            <div>أورنيك ١١٤ شرطة</div>
        </div>
        <!-- Document Title -->
        <div class="document-title">
            طلب تحرير شهادة إنهاء خدمة عسكرية "رديف دفعة"  @ToArabicNumerals(Model.ServiceEndDate?.ToString("yyyy/MM/dd"))م
        </div>

        <!-- Soldier Info -->
        <div class="soldier-info">
            <div>اسم المجند / @Model?.Name</div>
            <div>رقم الشرطة / @ToArabicNumerals(Model?.PoliceNumber)</div>
        </div>

        <!-- Main Table -->
        <table class="main-table">
            <thead>
                <tr>
                    <th style="width: 50%">محل الإقامة بالتفصيل بعد انتهاء الخدمة</th>
                    <th style="width: 50%">بيانات مدة الخدمة</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>العنوان / @Model?.Street</td>
                    <td>تاريخ إنهاء الخدمة: @ToArabicNumerals(Model?.ServiceEndDate?.ToString("yyyy/MM/dd"))</td>
                </tr>
                <tr>
                    <td>قسم / @Model?.Region</td>
                    <td>تاريخ التجنيد: @ToArabicNumerals(Model?.EnlistmentDate.ToString("yyyy/MM/dd"))</td>
                </tr>
                <tr>
                    <td>المحافظة / @Model?.City</td>
                    <td>مدة الخدمة: </td>
                </tr>
                <tr>
                    <td>الرقم القومي: @ToArabicNumerals(Model?.NationalId)</td>
                    <td>المدة الفاقدة: </td>
                </tr>
                <tr>
                    <td>الدرجة: جندي ٢</td>
                    <td>صافي مدة الخدمة: </td>
                </tr>
                <tr>
                    <td>مهنة المجند أثناء فترة التجنيد: @Model?.Job</td>
                    <td>تاريخ الاحتياط: </td>
                </tr>
                <tr>
                    <td colspan="2">درجة الأخلاق: </td>
                </tr>
            </tbody>
        </table>

        <!-- Committee Members -->
        <div class="section-title">أعضاء لجنة المراجعة</div>
        <div class="committee-members">
            <div class="member-card">
                <div class="member-rank">أ.ش/</div>
                <div class="member-section">
                    <div class="member-title">بلوكامين السجلات</div>
                    <div class="member-title">"@ViewBag.ConscriptsAffairsOfficerName"</div>
                </div>
               
            </div>

            <div class="member-card">
                <div class="member-rank">مقدم/</div>
                <div class="member-section">
                    <div class="member-title">رئيس قسم شئون المجندين</div>
                    <div class="member-title">"@ViewBag.ConscriptsAffairsPoliceManName"</div>
                </div>
              
            </div>
            <div class="member-card">
                <div class="member-rank">عميد/</div>
                <div class="member-section">
                    <div class="member-title">مدير @ViewBag.DepartmentName</div>
                    <div class="member-title">"@ViewBag.DepartmentDirectorName"</div>
                </div>
              
            </div>
        </div>

        <!-- Approval Section -->
        <div class="approval-section">
            إعتماد الإدارة العامة لشئون المجندين
        </div>

        <!-- Details Table -->
        <table class="details-table">
            <tbody>
                <tr>
                    <td>تاريخ التجنيد: :&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>
                    <td>إجمالي عدد الجزاءات بالحبس بالغياب (&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)</td>
                    <td>
                        <div>إجمالى عدد المحاكمات (&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)</div>
                        <div>مدة الغياب :&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
                    </td>
                </tr>
                <tr>
                    <td>بيانات الشهادة: </td>
                    <td>تاريخ آخر جزاء بالحبس:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</td>
                    <td>
                        <div>مدة العقوبة:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </div>
                        <div>إجمالى عدد المحاكمات الأخرى(&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)</div>
                    </td>
                </tr>
                <tr>
                    <td style="border-left: none !important;">&nbsp;&nbsp;&nbsp;&nbsp;ملاحظات أخرى: </td>
                    <td style="border-right: none !important;"></td>
                    <td>مدة العقوبة: </td>
                </tr>
            </tbody>
        </table>

        <!-- Signature Section -->

        <div class="signature-section">
            <div class="signature-box">
                <div>المراجع /</div>

            </div>
            <div class="signature-box">
                <div>التوقيع /</div>

            </div>
            <div class="signature-box">
                <div>تاريخ المراجعة /</div>

            </div>
        </div>

        
    </div>
</body>
</html>